    "eastmoney": {
      "base_url": "https://www.eastmoney.com",
      "enabled": true,
      "timeout": 10,
      "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
    },
    "yuncaijing": {
      "base_url": "https://www.yuncaijing.com",
      "enabled": true,
      "timeout": 10,
      "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
    },
    "cls": {
      "base_url": "https://www.cls.cn",
      "enabled": true,
      "timeout": 10,
      "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
    },
    "sse": {
      "base_url": "http://www.sse.com.cn",
